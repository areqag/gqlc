#!/usr/bin/env bash
# GH↔bd sync helper. Single sync surface shared by:
#   - .githooks/post-merge      (pull, on git pull/merge)
#   - .githooks/pre-push        (push, on git push)
#   - .claude/settings.json     (pull, on Claude Code session start)
#
# Args: pull | push
# Silent to stdout/stderr — caller decides whether to redirect or tail.
# Never fails: exits 0 on any error so the git/session operation continues.
#
# Design: human works through GitHub issues; agents work through bd.
#   - pull:  mirror GH state (creates, closes, comments) into bd.
#            --prefer-github breaks ties toward GH; GH is source of truth.
#   - push:  mirror bd-created beads that have no GH mirror yet, AND close
#            GH issues whose bead was closed locally.
#            Deliberately does NOT run `bd github sync --push-only` (which
#            takes ~30s scanning every bead) — its close propagation is also
#            unreliable (memory: bd-github-sync-quirks). Instead:
#              1. `bd github push <ids>` per new bead (no external_ref).
#              2. Bulk `gh issue list --state open` intersected with
#                 closed-bd beads bearing an external_ref; each mismatch
#                 gets `gh issue close`.

_action="${1:-}"
case "$_action" in pull|push) ;; *)
  echo "usage: $0 pull|push" >&2
  exit 0
esac

command -v bd >/dev/null 2>&1 || exit 0
command -v gh >/dev/null 2>&1 || exit 0
_token=$(gh auth token 2>/dev/null) || exit 0
[ -n "$_token" ] || exit 0

if [ "$_action" = "pull" ]; then
  GITHUB_TOKEN="$_token" bd github sync --pull-only --prefer-github || true
  exit 0
fi

# push
_beads=$(bd list --status all --limit 0 --json 2>/dev/null || echo '[]')

_new=$(printf '%s' "$_beads" | python3 -c '
import json, sys
try:
    for b in json.load(sys.stdin):
        if not b.get("external_ref"):
            print(b["id"])
except Exception:
    pass
' 2>/dev/null)
if [ -n "$_new" ]; then
  GITHUB_TOKEN="$_token" bd github push $_new || true
fi

# Close GH mirrors for beads that are closed locally but still open on GH.
# One bulk `gh issue list` + one `gh issue close` per mismatch; skipped when
# there are none. Idempotent: closing an already-closed GH issue is a no-op.
_open_gh=$(GITHUB_TOKEN="$_token" gh issue list --state open --limit 500 --json number 2>/dev/null || echo '[]')
printf '%s' "$_beads" | GITHUB_TOKEN="$_token" python3 -c '
import json, sys, re, subprocess
try:
    open_nums = {i["number"] for i in json.loads(sys.argv[1])}
except Exception:
    open_nums = set()
if not open_nums:
    sys.exit(0)
try:
    beads = json.load(sys.stdin)
except Exception:
    beads = []
pat = re.compile(r"/issues/(\d+)$")
for b in beads:
    if b.get("status") != "closed":
        continue
    m = pat.search(b.get("external_ref") or "")
    if not m:
        continue
    n = int(m.group(1))
    if n not in open_nums:
        continue
    tag = ((b.get("close_reason") or "").splitlines() or [""])[0].strip()
    if len(tag) > 300:
        tag = tag[:297] + "..."
    bid = b["id"]
    body = f"Auto-close: bead {bid} closed locally."
    if tag:
        body += f" {tag}"
    subprocess.run(
        ["gh", "issue", "close", str(n), "--comment", body],
        capture_output=True, check=False,
    )
' "$_open_gh" >/dev/null 2>&1 || true
exit 0
