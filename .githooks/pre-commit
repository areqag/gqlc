#!/usr/bin/env bash
# Pre-commit hook: block direct commits to master/main.
# Activated by: git config core.hooksPath .githooks
# (run `just init` after cloning)

# Allow test harness to override the branch name for testing
if [ -n "${BRANCH_OVERRIDE:-}" ]; then
  BRANCH="$BRANCH_OVERRIDE"
else
  BRANCH="$(git rev-parse --abbrev-ref HEAD)"
fi

if [ "$BRANCH" = "master" ] || [ "$BRANCH" = "main" ]; then
  echo "ERROR: Direct commits to $BRANCH are blocked." >&2
  echo "Create a feature branch with: git switch -c <branch>" >&2
  exit 1
fi

exit 0
