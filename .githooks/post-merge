#!/usr/bin/env bash
# Post-merge hook: pull GH issue state into bd so bd reflects human-side
# actions taken in the GH UI (closes, comments, new issues).
# Activated by: git config core.hooksPath .githooks
# (run `just init` after cloning)
# Silent, non-blocking — never fail the underlying `git pull`.
exec "$(dirname "$0")/bd-gh-sync" pull >/dev/null 2>&1
